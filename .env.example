# OpenAI-compatible local endpoint. Keep a non-empty key for OpenAI client validation.
OPENAI_BASE_URL=http://localhost:20128/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=replace-with-local-api-key
OFFLINE=false
ALLOW_MODEL_FALLBACK=true

# Execution budgets. MAX_TURNS must never exceed 40.
MAX_TURNS=40
MAX_GRAPH_STEPS=20
MAX_RETRIEVAL_LOOPS=3
MAX_TOOL_CALLS=30
MAX_MODEL_CALLS=12
MAX_TOTAL_TOKENS=30000
MAX_OUTPUT_TOKENS_PER_CALL=1200
MAX_RUNTIME_SECONDS=30
PER_TOOL_TIMEOUT_SECONDS=8
RETRY_COUNT_PER_TOOL=2

# Runtime trace output. Logs must not contain API keys or hidden model reasoning.
LOG_LEVEL=INFO
LOG_DIR=logs/runs
