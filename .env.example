# OpenAI-compatible local endpoint. Keep a non-empty key for OpenAI client validation.
OPENAI_BASE_URL=http://localhost:20128/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=replace-with-local-api-key
OFFLINE=false
ALLOW_MODEL_FALLBACK=true

# Deep Agents supervisor. Uses the same OpenAI-compatible endpoint by default.
ENABLE_DEEP_AGENT=true
DEEP_AGENT_MODEL=
PROMPT_PROFILE=safety_default

# Langfuse tracing/evaluation. Set ENABLE_LANGFUSE=true only when keys are valid.
ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=pk-lf-replace-me
LANGFUSE_SECRET_KEY=sk-lf-replace-me
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=aabw-hackathon-demo

# Optional LLM-as-a-judge evaluation. Keep disabled for deterministic offline tests.
ENABLE_LLM_JUDGE=false
LLM_JUDGE_MODEL=gpt-4o-mini

# Execution budgets. MAX_TURNS must never exceed 40.
MAX_TURNS=40
MAX_GRAPH_STEPS=20
MAX_RETRIEVAL_LOOPS=3
MAX_TOOL_CALLS=30
MAX_MODEL_CALLS=12
MAX_TOTAL_TOKENS=30000
MAX_OUTPUT_TOKENS_PER_CALL=1200
MAX_RUNTIME_SECONDS=90
MODEL_TIMEOUT_SECONDS=60
PER_TOOL_TIMEOUT_SECONDS=8
RETRY_COUNT_PER_TOOL=2
RETRIEVAL_TOP_K=13

# Runtime trace output. Logs must not contain API keys or hidden model reasoning.
LOG_LEVEL=INFO
LOG_DIR=logs/runs

# Demo API and PDF ingestion output.
API_HOST=127.0.0.1
API_PORT=8002
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]
UPLOAD_DIR=data/uploads
INGESTED_CORPUS_PATH=data/ingested_corpus.json

# Optional AWS deployment variables. Do not list AWS as "used" in the submission
# unless these services are actually integrated and shown in the demo.
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=replace-me
# AWS_SECRET_ACCESS_KEY=replace-me
# S3_BUCKET=replace-me
# RDS_POSTGRES_DSN=replace-me
# OPENSEARCH_URL=replace-me
